{
  "manifest_version": 3,
  "name": "New Tab Focus",
  "short_name": "Nu Tab",
  "version": "1.0.0",
  "description": "A custom new tab page with a clock, favourites grid, live weather, sticky notes, and an autofocused URL search bar.",
  "minimum_chrome_version": "88",
  "action": {
    "default_popup": "nutab-ext/nutab-ext.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "history", "topSites"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "nutab-relay/nutab-relay.html"
  },
  "options_ui": {
    "page": "nutab-ext/nutab-ext.html",
    "open_in_tab": true
  }
}
